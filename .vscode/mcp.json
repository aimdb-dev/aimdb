{
    "servers": {
        "aimdb-weather": {
            "type": "http",
            "url": "http://aimdb.dev/mcp"
        },
        "aimdb-local": {
            "type": "stdio",
            "command": "cargo",
            "args": [
                "run",
                "--manifest-path",
                "/aimdb_ws/aimdb/tools/aimdb-mcp/Cargo.toml",
                "--",
                "--socket",
                "/tmp/aimdb-demo.sock"
            ]
        }
    }
}